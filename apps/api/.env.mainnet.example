# ─── SwarmHaul API — Mainnet Configuration ────────────────────────────────────
#
# LEGAL WARNING: Before deploying this to Solana mainnet-beta you MUST obtain
# CASP (Crypto Asset Service Provider) authorization under MiCA and KWG §1(1a)(6)
# (German crypto custody license). The coordinator keypair signing payout
# transactions constitutes custodial service provision under EU/German law.
# See CONTRIBUTING.md and the legal-disclaimer section of the pitch site.
#
# Estimated cost: €750K–€1M capital + 6–12 months BaFin application process.
# Consult a licensed crypto compliance firm before any mainnet launch with real users.
# ────────────────────────────────────────────────────────────────────────────────

DATABASE_URL=postgresql://swarmhaul:<PASSWORD>@<HOST>:5432/swarmhaul_prod

# ── Solana mainnet-beta ────────────────────────────────────────────────────────
# Use a private RPC endpoint (Helius, QuickNode, Triton) — public mainnet has
# strict rate limits that will cause coordinator tx failures under load.
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=<HELIUS_API_KEY>
SOLANA_CLUSTER=mainnet-beta

# ── Coordinator keypair ───────────────────────────────────────────────────────
# This wallet signs form_task_swarm / assign_task_leg / confirm_task_leg /
# settle_task transactions. It needs enough SOL for transaction fees (~0.000005
# SOL per tx). Keep it funded; drain it via settle_task surplus returns.
# NEVER commit the keypair file or the path to a public repository.
PROTOCOL_AUTHORITY_KEYPAIR_PATH=/etc/swarmhaul/coordinator.json

# ── Platform fee (set when CASP license obtained) ─────────────────────────────
# PLATFORM_FEE_BPS=50   # 0.5% on surplus — pass to coordinatorSettleTask()
# PLATFORM_WALLET=<YOUR_PLATFORM_WALLET_PUBKEY>

PORT=3001
