generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Package {
  id              String    @id @default(uuid())
  shipperPubkey   String
  originLat       Float
  originLng       Float
  destLat         Float
  destLng         Float
  description     String
  weightKg        Float
  volumeLitres    Float
  maxBudgetSol    Float
  status          String    @default("listed")
  listedAt        DateTime  @default(now())
  deliveredAt     DateTime?
  /// On-chain PackageAccount PDA (set when shipper signs list_package)
  onChainPackage  String?
  /// On-chain vault PDA holding the escrow lamports
  onChainVault    String?
  /// Tx signature of the list_package transaction
  listSignature   String?
  swarm           Swarm?
}

model Swarm {
  id            String   @id @default(uuid())
  packageId     String   @unique
  package       Package  @relation(fields: [packageId], references: [id])
  /// On-chain SwarmAccount PDA
  onChainSwarm  String?
  /// Tx signature of the form_swarm + assign_leg combined transaction
  formSignature String?
  totalCostSol  Float
  status        String   @default("forming")
  formedAt      DateTime @default(now())
  legs          Leg[]
}

model Leg {
  id                   String    @id @default(uuid())
  swarmId              String
  swarm                Swarm     @relation(fields: [swarmId], references: [id])
  legIndex             Int       @default(0)
  agentPubkey          String
  pickupLat            Float
  pickupLng            Float
  dropoffLat           Float
  dropoffLng           Float
  distanceKm           Float
  estimatedDurationMin Int
  agreedPaymentSol     Float
  status               String    @default("pending")
  completedAt          DateTime?
  /// On-chain LegAccount PDA
  onChainLeg           String?
  /// Tx signature when courier confirms the leg
  confirmSignature     String?
}

model VehicleProfile {
  agentPubkey         String   @id
  ownerName           String
  carMake             String
  carModel            String
  bootVolumeLitres    Float
  fuelConsumptionL100 Float
  fuelCostEurPerLitre Float
  hourlyRateEur       Float
  isAutonomous        Boolean  @default(false)
  registeredAt        DateTime @default(now())
}

model Bid {
  id                   String   @id @default(uuid())
  packageId            String
  agentPubkey          String
  pickupLat            Float
  pickupLng            Float
  dropoffLat           Float
  dropoffLng           Float
  distanceKm           Float
  estimatedDurationMin Int
  costSol              Float
  reasoning            String?
  expiresAt            DateTime
  createdAt            DateTime @default(now())
}

model AgentReputation {
  agentPubkey        String   @id
  legsCompleted      Int      @default(0)
  legsAccepted       Int      @default(0)
  avgDeliveryTimeSec Float    @default(0)
  reliabilityScore   Float    @default(50)
  updatedAt          DateTime @updatedAt
}

model NegotiationMessage {
  id              String   @id @default(uuid())
  packageId       String
  fromAgent       String
  toAgent         String?
  action          String
  proposedCostSol Float?
  reasoning       String?
  createdAt       DateTime @default(now())
}

// ─── Digital Task Track ────────────────────────────────────────────────────

model DigitalTask {
  id             String       @id @default(uuid())
  shipperPubkey  String
  title          String
  description    String
  maxBudgetSol   Float
  status         String       @default("listed")
  listSignature  String?
  onChainTask    String?
  onChainVault   String?
  onChainSwarm   String?
  listedAt       DateTime     @default(now())
  completedAt    DateTime?
  legs           DigitalLeg[]
}

model DigitalLeg {
  id              String      @id @default(uuid())
  taskId          String
  task            DigitalTask @relation(fields: [taskId], references: [id])
  sequence        Int
  instruction     String
  agentPubkey     String?
  bidSol          Float?
  paymentLamports BigInt?
  status          String      @default("open")
  result          String?
  onChainLeg      String?
  startedAt       DateTime?
  completedAt     DateTime?
}

model DigitalAgentProfile {
  agentPubkey   String    @id
  displayName   String?
  capabilities  String[]
  lastAirdropAt DateTime?
  registeredAt  DateTime  @default(now())
}

// ─── Hackathon Mainnet Reward Claims ──────────────────────────────────────────
// Window: 2026-05-11 00:00:00 UTC → 2026-05-17 23:59:59 UTC
// Participants register their devnet agent pubkey + mainnet pubkey.
// After the window closes, rewards are distributed manually to mainnetPubkey.

model RewardClaim {
  id                     String    @id @default(uuid())
  /// Agent's devnet pubkey (the one that earned SOL in the hackathon)
  devnetPubkey           String    @unique
  /// Mainnet pubkey to receive the equivalent SOL payout
  mainnetPubkey          String
  /// Total devnet earnings (sum of completed DigitalLeg paymentLamports)
  devnetEarningsLamports BigInt    @default(0)
  claimedAt              DateTime  @default(now())
  /// pending → paid after manual distribution
  status                 String    @default("pending")
  paidAt                 DateTime?
  paidTxSig             String?
}
