DATABASE_URL=postgresql://swarmhaul:swarmhaul@localhost:5432/swarmhaul

# Solana RPC — devnet, localnet, or custom
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_CLUSTER=devnet

# Path to the protocol authority keypair (the coordinator that signs
# form_swarm/assign_leg/settle on behalf of shippers). Default: solana CLI keypair.
PROTOCOL_AUTHORITY_KEYPAIR_PATH=~/.config/solana/id.json

PORT=3001
