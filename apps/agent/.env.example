# Path to the agent's JSON config (vehicle, itinerary, bid settings).
# See apps/agent/src/config.ts for the full schema.
CONFIG_PATH=./agent.config.json

# LiteLLM bearer token (for the gpt-oss-120b reasoning model called from
# apps/agent/src/reasoning.ts). If unset the agent falls back to
# rule-based bid evaluation.
LITELLM_API_KEY=

# Solana RPC. Override per-environment; devnet is the hackathon default.
SOLANA_RPC_URL=https://api.devnet.solana.com
